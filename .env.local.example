# Copy this file to .env.local and fill in the values.
# Find these in the Supabase dashboard under Project Settings → API Keys.

# Supabase project API URL, e.g. https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key (sb_publishable_...). Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key (sb_secret_...). Server-only — never expose to the browser.
SUPABASE_SECRET_KEY=

# Anthropic API key for the AI briefing feature (added in a later step).
ANTHROPIC_API_KEY=
